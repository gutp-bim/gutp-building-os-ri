{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GET /floors response contract",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["dtId", "id", "name", "floorNumber"],
    "properties": {
      "dtId":        { "type": "string" },
      "id":          { "type": "string" },
      "name":        { "type": "string" },
      "floorNumber": { "type": "integer" },
      "buildingId":  { "type": ["string", "null"] }
    },
    "additionalProperties": false
  },
  "examples": [
    [
      { "dtId": "eng2-3f-twin", "id": "eng2-3f", "name": "3階", "floorNumber": 3, "buildingId": "eng2" }
    ]
  ]
}
