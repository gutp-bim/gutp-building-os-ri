      "panel":            { "type": ["string", "null"] },
      "labels":           { "type": ["string", "null"] },
      "scale":            { "type": ["number", "null"] },
      "installationArea": { "type": ["string", "null"] },
      "unit":             { "type": ["string", "null"] },
