{
    "$schema": "azure_metrics_config_schema",
    "description": "Azure Monitor メトリクス収集設定",
    "azure": {
        "subscription_id": "${AZURE_SUBSCRIPTION_ID}",
        "tenant_id": "${AZURE_TENANT_ID}",
        "client_id": "${AZURE_CLIENT_ID}",
        "client_secret": "${AZURE_CLIENT_SECRET}",
        "use_environment_credential": true
    },
    "resources": {
        "functions": [
            {
                "resource_id": "/subscriptions/${AZURE_SUBSCRIPTION_ID}/resourceGroups/${FUNCTION_RESOURCE_GROUP}/providers/Microsoft.Web/sites/${FUNCTION_APP_NAME}",
                "name": "${FUNCTION_APP_NAME}",
                "enabled": true
            }
        ],
        "cosmosdb": [
            {
                "resource_id": "/subscriptions/${AZURE_SUBSCRIPTION_ID}/resourceGroups/${COSMOSDB_RESOURCE_GROUP}/providers/Microsoft.DocumentDB/databaseAccounts/${COSMOSDB_ACCOUNT_NAME}",
                "name": "${COSMOSDB_ACCOUNT_NAME}",
                "database_name": "${COSMOSDB_DATABASE_NAME}",
                "enabled": true
            }
        ],
        "iothub": [
            {
                "resource_id": "/subscriptions/${AZURE_SUBSCRIPTION_ID}/resourceGroups/${IOTHUB_RESOURCE_GROUP}/providers/Microsoft.Devices/IotHubs/${IOTHUB_NAME}",
                "name": "${IOTHUB_NAME}",
                "enabled": true
            }
        ]
    },
    "collection": {
        "interval_seconds": 60,
        "enabled": true,
        "export_format": [
            "csv",
            "json",
            "excel"
        ],
        "generate_graphs": true
    },
    "output": {
        "base_directory": "./results/metrics",
        "raw_data_filename": "azure_metrics_raw_{timestamp}.csv",
        "summary_filename": "azure_metrics_summary_{timestamp}.csv",
        "graphs_directory": "graphs_{timestamp}"
    },
    "metrics_enabled": {
        "functions": {
            "execution_time": true,
            "execution_count": true,
            "errors": true,
            "instances": true,
            "memory": true
        },
        "cosmosdb": {
            "ru_consumption": true,
            "throttling": true,
            "response_time": true,
            "request_charge": true
        },
        "iothub": {
            "telemetry_messages": true,
            "throughput": true,
            "connected_devices": true,
            "routing_latency": true
        }
    }
}

