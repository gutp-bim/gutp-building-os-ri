{
  "deviceId": "{device_id}",
  "timestamp": "{timestamp}",
  "messageType": "telemetry",
  "protocol": "hvac",
  "data": {
    "points": [
      {
        "pointId": "temp_setpoint",
        "value": "{random_float:18:28}",
        "unit": "degC",
        "description": "温度設定値"
      },
      {
        "pointId": "current_temp",
        "value": "{random_float:15:30}",
        "unit": "degC", 
        "description": "現在温度"
      },
      {
        "pointId": "humidity_setpoint",
        "value": "{random_float:40:60}",
        "unit": "%",
        "description": "湿度設定値"
      },
      {
        "pointId": "current_humidity",
        "value": "{random_float:30:70}",
        "unit": "%",
        "description": "現在湿度"
      },
      {
        "pointId": "fan_speed",
        "value": "{random_int:0:100}",
        "unit": "%",
        "description": "ファン速度"
      },
      {
        "pointId": "operating_mode",
        "value": "{random_choice:cooling,heating,auto,off}",
        "unit": "",
        "description": "運転モード"
      }
    ]
  },
  "metadata": {
    "systemId": "hvac-{random_int:1:10}",
    "unitId": "unit-{random_int:1:50}",
    "location": "floor-{random_int:1:10}-zone-{random_int:1:20}"
  }
}