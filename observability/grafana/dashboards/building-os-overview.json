{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.1.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "Building OS API Server - Request Rate, Latency, Error Rate",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum by (http_request_method, http_route) (rate(http_server_request_duration_seconds_count{job=\"building-os-api\"}[1m]))",
          "legendFormat": "{{http_request_method}} {{http_route}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "P99 Latency (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_request_duration_seconds_bucket{job=\"building-os-api\"}[5m]))) * 1000",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" }
      }
    },
    {
      "id": 3,
      "title": "Error Rate (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "100 * sum(rate(http_server_request_duration_seconds_count{http_response_status_code=~\"5..\",job=\"building-os-api\"}[1m])) / sum(rate(http_server_request_duration_seconds_count{job=\"building-os-api\"}[1m]))",
          "legendFormat": "Error %"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "max": 100 }
      }
    },
    {
      "id": 4,
      "title": "Active Requests",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "http_server_active_requests{job=\"building-os-api\"}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Connector Processing Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "sum by (connector, result) (rate(building_os_connector_messages_processed_total[1m]))",
          "legendFormat": "{{connector}} {{result}}"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["building-os", "observability"],
  "time": { "from": "now-1h", "to": "now" },
  "title": "Building OS Overview",
  "uid": "building-os-overview",
  "version": 1
}
