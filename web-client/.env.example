# =============================================================================
# web-client 環境変数サンプル
# =============================================================================
# Usage:
#   cp .env.example .env.local   # then edit values as needed
#   yarn dev
#
# NEXT_PUBLIC_* は Next.js がブラウザバンドルに埋め込む公開変数です。
# シークレットをこの prefix に入れないでください。
# =============================================================================

# API Server URL
# dotnet run --launch-profile WithLocal のデフォルト: http://localhost:5000
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000

# Keycloak OIDC（認証を有効にする場合: dotnet run --launch-profile WithLocalAuth）
NEXT_PUBLIC_KEYCLOAK_AUTHORITY=http://localhost:8080/realms/building-os
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=web-client

# Help assistant（experimental, オプション）
# POST /api/assistant/chat を有効にするには API Server 側で ASSISTANT_LLM_URL の設定が必要。
NEXT_PUBLIC_ASSISTANT_ENABLED=false
