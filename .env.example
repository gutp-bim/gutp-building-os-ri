# =============================================================================
# docker-compose.oss.yaml credential overrides
# =============================================================================
# These values are read by docker-compose.oss.yaml via ${VAR:-default}
# interpolation. The defaults baked into the compose file are LOCAL DEVELOPMENT
# ONLY and MUST NOT be used in production.
#
# Usage:
#   cp .env.example .env      # then edit values below
#   docker compose -f docker-compose.oss.yaml up -d
#
# Production: do NOT ship a .env file with these. Inject secrets via your
# orchestrator (Kubernetes Secret, Docker secret, or an external secret
# manager) and set non-default values for every credential below.
# =============================================================================

# ── PostgreSQL + TimescaleDB ────────────────────────────────────────────────
POSTGRES_USER=buildingos
POSTGRES_PASSWORD=buildingos
POSTGRES_DB=buildingos

# ── MinIO (S3-compatible object storage) ────────────────────────────────────
MINIO_ROOT_USER=buildingos
MINIO_ROOT_PASSWORD=buildingos123

# ── Keycloak (OIDC) bootstrap admin ─────────────────────────────────────────
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=admin

# ── Grafana ─────────────────────────────────────────────────────────────────
# Local dev keeps anonymous Admin access for zero-friction dashboards.
# Production: set GF_AUTH_ANONYMOUS_ENABLED=false and a strong admin password.
GF_AUTH_ANONYMOUS_ENABLED=true
GF_AUTH_ANONYMOUS_ORG_ROLE=Admin
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# ── MQTT (Mosquitto — opt-in, --profile mqtt) ────────────────────────────────
MQTT_DEVICES_PASSWORD=buildingos-devices

# ── Azure IoT Hub (optional — development edge-device simulator only) ─────────
# Required only when running Tools/development-edge-device against Azure IoT Hub.
# NOT needed for the OSS local stack (docker-compose.oss.yaml).
# Obtain from: Azure Portal → IoT Hub → Devices → <device> → Connection string
EDGE_HUB_CONNECTION_STRING="HostName=<your-iot-hub>.azure-devices.net;DeviceId=<device-id>;SharedAccessKey=<base64-key>"
IOTHUB_DEVICE_CONNECTION_STRING="HostName=<your-iot-hub>.azure-devices.net;DeviceId=<device-id>;SharedAccessKey=<base64-key>"
